// Prisma schema for ARZAMA project - MongoDB
// NOTE: You must create a DATABASE_URL in your .env (mongodb://...) and run `npx prisma generate`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  enrollments Enrollment[]
  reviews     Review[]

  @@map("users")
}

model Course {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  courseId    String       @unique // Custom course identifier (english, french, portuguese)
  name        String
  description String
  priceCents  Int
  currency    String       @default("inr")

  enrollments Enrollment[]
  reviews     Review[]

  @@map("courses")
}

model Enrollment {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  user        User           @relation(fields: [userId], references: [id])
  userId      String         @db.ObjectId
  course      Course         @relation(fields: [courseId], references: [id])
  courseId    String         @db.ObjectId
  status      EnrollmentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  paymentReceipt PaymentReceipt?

  @@map("enrollments")
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String   @db.ObjectId
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@map("reviews")
}

model PaymentReceipt {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  enrollment         Enrollment  @relation(fields: [enrollmentId], references: [id])
  enrollmentId       String      @unique @db.ObjectId
  stripeSessionId    String      @unique // Payment ID (reusing field name for compatibility)
  stripePaymentIntentId String?
  amountCents        Int
  currency           String
  cardBrand          String?
  cardLast4          String?
  createdAt          DateTime    @default(now())

  @@map("payment_receipts")
}

enum EnrollmentStatus {
  PENDING
  PAID
  CANCELED
}
